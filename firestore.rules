rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Posts públicos: cualquier usuario autenticado (incl. anónimos) puede leer y crear.
    // Solo el autor puede borrar. Cualquier autenticado puede actualizar (likes).
    match /posts/{postId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;
    }

    // Datos de cada usuario: solo él mismo puede leer y escribir.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
