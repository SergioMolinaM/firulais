rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Cualquier usuario autenticado (incluidos anónimos) puede leer y escribir.
    // Suficiente para beta. Restringir por uid en siguiente fase.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
